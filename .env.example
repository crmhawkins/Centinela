# CENTINELA – Environment Variables
# ==================================
# Copy this file to .env and fill in your values before deploying.
#
#   cp .env.example .env
#   nano .env
#
# The .env file is loaded automatically by Docker Compose.
# NEVER commit .env to version control – it may contain secrets.

# ---------------------------------------------------------------------------
# Core settings
# ---------------------------------------------------------------------------

# Absolute path to the main configuration file (inside the container).
# The default matches the volume mount in docker-compose.yml.
CENTINELA_CONFIG=/app/config/centinela.yml

# Container timezone. Use a value from the IANA tz database.
# Examples: Europe/Madrid, America/New_York, UTC, Asia/Tokyo
TZ=Europe/Madrid

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# INFO is the recommended level for production.
CENTINELA_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# SMTP credentials (optional – can also be set in centinela.yml)
# Environment variables take precedence over centinela.yml values.
# ---------------------------------------------------------------------------

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=centinela@yourdomain.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=CENTINELA <centinela@yourdomain.com>
# SMTP_TLS=true
# SMTP_SSL=false

# ---------------------------------------------------------------------------
# Database (optional override)
# ---------------------------------------------------------------------------

# Override the db_url from centinela.yml.
# Useful for pointing to an external PostgreSQL instance without editing yml.
# DB_URL=postgresql+asyncpg://centinela:secret@db-host:5432/centinela

# ---------------------------------------------------------------------------
# Webhook secrets (optional)
# ---------------------------------------------------------------------------

# Shared secret added to the X-Centinela-Signature header on outgoing webhooks.
# Allows receiving services to verify the payload origin.
# WEBHOOK_SECRET=change-me-to-a-random-string

# ---------------------------------------------------------------------------
# Development / debug overrides
# ---------------------------------------------------------------------------

# Set to 1 to write pretty-printed JSON to stdout instead of structured logs.
# Useful during local development. Leave unset in production.
# CENTINELA_DEV_MODE=0
